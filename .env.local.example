# ─── Supabase (auth + data) ──────────────────────────────────────────────────
# Create a NEW, separate Supabase project for the platform (not the Divine
# Blueprint one). Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://your-platform-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Coolify (the hosting engine — wired in a later milestone) ────────────────
# COOLIFY_API_URL=https://coolify.your-server.com/api/v1
# COOLIFY_API_TOKEN=

# ─── Stripe Connect (multi-tenant payments — DORMANT until set) ───────────────
# Server-only. With no STRIPE_SECRET_KEY the Payments card shows a "not enabled"
# note and nothing runs. Set the secret key + enable Connect on the platform's
# Stripe account to turn it on. The webhook secret is for the stage-2 webhook.
# STRIPE_SECRET_KEY=sk_live_or_test_...
# STRIPE_CONNECT_WEBHOOK_SECRET=whsec_...
