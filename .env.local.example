# ─── Supabase (auth + data) ──────────────────────────────────────────────────
# Create a NEW, separate Supabase project for the platform (not the Divine
# Blueprint one). Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://your-platform-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Coolify (the hosting engine — wired in a later milestone) ────────────────
# COOLIFY_API_URL=https://coolify.your-server.com/api/v1
# COOLIFY_API_TOKEN=

# ─── Stripe (payments — DORMANT until set) ───────────────────────────────────
# Server-only. With no STRIPE_SECRET_KEY the Payments card shows a "not enabled"
# note and nothing runs.
#
# STRIPE_SECRET_KEY — the platform owner's own Stripe secret key. This is the
# account that DIRECT charges settle into (the default: Buy buttons charge
# straight to the owner). REQUIRED to take any payment.
# STRIPE_SECRET_KEY=sk_live_or_test_...
#
# STRIPE_WEBHOOK_SECRET — signing secret of the platform ACCOUNT's OWN webhook
# endpoint (Stripe → Webhooks → add endpoint listening to "Your account" events,
# checkout.session.completed, URL /api/stripe/webhook). REQUIRED for direct
# charges (the default path) to RECORD as sales. Without it the customer is still
# charged, but the sale never lands in the dashboard.
# STRIPE_WEBHOOK_SECRET=whsec_...
#
# STRIPE_CONNECT_WEBHOOK_SECRET — only needed for the OPTIONAL Connect path
# (letting a separate seller use their own connected Stripe account). Signing
# secret of a webhook endpoint listening to "Connected accounts" events. Leave
# unset if every sale settles into the owner's own account.
# STRIPE_CONNECT_WEBHOOK_SECRET=whsec_...

# ─── Email (booking confirmations + notifications — DORMANT until set) ───────
# Server-only. Without RESEND_API_KEY no emails send and nothing breaks: a client
# books (and pays) exactly as before, just with no confirmation email. Once set,
# every confirmed booking emails the client (with a one-tap .ics calendar invite)
# and notifies the owner.
#
# RESEND_API_KEY — a Resend API key (https://resend.com). Without it, no emails
# send (nothing breaks).
# RESEND_API_KEY=re_...
#
# BOOKING_FROM_EMAIL — the "From" address; MUST be a Resend-verified sender.
# Defaults to "Anima Temple <bookings@animatemple.com>" if unset.
# BOOKING_FROM_EMAIL=Anima Temple <bookings@yourdomain.com>
